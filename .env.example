# Sherwood — environment template. Copy to .env and fill in. NEVER commit .env.

# ---- Chain (Robinhood Chain) ----
# Mainnet: 4663 / https://rpc.mainnet.chain.robinhood.com
# Testnet: 46630 / https://rpc.testnet.chain.robinhood.com
CHAIN_ID=46630
RPC_URL=https://rpc.testnet.chain.robinhood.com

# ---- Deploy (script/Deploy.s.sol) ----
DEPLOYER_PRIVATE_KEY=0x...
ROUTER=0xcaf681a66d020601342297493863e78c959e5cb2   # Uniswap v3 SwapRouter02 (mainnet)
LEVELS=23                                            # MUST equal Transaction(23,..) in the circuit
OWNER=                                               # allowlist admin (defaults to deployer)
ASSET_0=0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168   # USDG (mainnet; testnet: 0x7E95..802F)
ASSET_1=0xaF3D76f1834A1d425780943C99Ea8A608f8a93f9   # e.g. AAPL stock token (mainnet)

# ---- Relayer (relayer/src/server.ts) ----
POOL_ADDRESS=0x...            # deployed Sherwood pool
RELAYER_PRIVATE_KEY=0x...     # funded hot wallet that submits transactions
MIN_FEE=0                     # minimum accepted fee (smallest unit of the tx asset)
PORT=8787
# comma-separated denylist for the public-leg sanctions screen (stub)
SANCTIONS_DENYLIST=
