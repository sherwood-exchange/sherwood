# Auto-HTTPS reverse proxy. DOMAIN + ACME_EMAIL come from the container env.
# Serves the static web app and proxies the relayer API under /relayer/*.
{$DOMAIN} {
	encode gzip zstd

	# Relayer API: strip the /relayer prefix and forward to the relayer service.
	# The web app calls https://{$DOMAIN}/relayer/{info,transact,health}.
	handle_path /relayer/* {
		reverse_proxy relayer:8787
	}

	# Points API: https://{$DOMAIN}/points/{leaderboard,points/<addr>,referral,info}.
	handle_path /points/* {
		reverse_proxy points:8788
	}

	# JSON-RPC proxy: https://{$DOMAIN}/rpc — lets the browser reach the Robinhood RPC
	# over TLS via the VPS (no VPN, no mixed content). The proxy forwards POST bodies.
	handle /rpc* {
		reverse_proxy rpc:8791
	}

	# Investing-planner agent ("Robin"): https://{$DOMAIN}/agent/{plan,universe,health}.
	# Strip the /agent prefix and forward to the plan service (LLM key stays server-side).
	handle_path /agent/* {
		reverse_proxy plan:8795
	}

	# GeckoTerminal proxy: https://{$DOMAIN}/gtproxy/* → api.geckoterminal.com. Their Cloudflare
	# blocks cross-origin browser requests, so token-page charts/trades must be fetched same-origin.
	handle_path /gtproxy/* {
		reverse_proxy https://api.geckoterminal.com {
			header_up Host api.geckoterminal.com
			header_up -Origin
			# GT's Rails routes by forwarded host — leaking sherwood.spot 404s every request
			header_up -X-Forwarded-Host
		}
	}

	# Static single-page app (circuit .wasm/.zkey are served from /srv/circuits).
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	tls {$ACME_EMAIL}
}
