# Copy to `.env` (same directory) and fill in. This file drives docker-compose:
# both build args (VITE_*) and container env (relayer + Caddy). Never commit `.env`.

# --- Public endpoints (Caddy auto-TLS) ---
DOMAIN=sherwood.example.com
ACME_EMAIL=you@example.com

# --- Web build (baked into the bundle) ---
# VITE_RELAYER_URL must be https://<DOMAIN>/relayer (Caddy strips the /relayer prefix).
VITE_RELAYER_URL=https://sherwood.example.com/relayer
VITE_POINTS_URL=https://sherwood.example.com/points
VITE_RPC_URL=https://rpc.testnet.chain.robinhood.com

# --- Relayer service ---
POOL_ADDRESS=0x8BB9293a06a84280242E66ad62c8Db00E517639a
CHAIN_ID=46630
RPC_URL=https://rpc.testnet.chain.robinhood.com
# Dedicated, FUNDED testnet hot wallet — must differ from your shielding wallet.
# (Generate one and send it a little testnet ETH; never reuse a mainnet key.)
RELAYER_PRIVATE_KEY=0xREPLACE_WITH_A_FUNDED_TESTNET_RELAYER_KEY
# Minimum accepted fee (smallest unit of the tx asset). 0 = relayer sponsors gas
# (fine for a demo; the web sends fee=0). Rate limits below bound the exposure.
MIN_FEE=0
RATE_LIMIT_PER_MIN=10
RATE_LIMIT_GLOBAL_PER_MIN=120
TRUST_PROXY=1
PORT=8787

# --- Points indexer (reuses POOL_ADDRESS / RPC_URL / CHAIN_ID above) ---
POINTS_FROM_BLOCK=88566236
POINTS_DATA=points-data/state.json

# --- Cross-chain private ramp proxy (relayer /xchain/*) — keys are backend-only ---
# HoudiniSwap Partner API v2 (https://app.houdiniswap.com/partner/dashboard)
HOUDINI_API_KEY=
HOUDINI_API_SECRET=
# AnySwap Exchange API
ANYSWAP_API_KEY=
