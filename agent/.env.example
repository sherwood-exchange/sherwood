# Virtuals GAME API key (from console.game.virtuals.io) — required to run the agent loop
GAME_API_KEY=

# Optional: X / Twitter posting. Get a token by running:
#   npx @virtuals-protocol/game-twitter-node auth -k <GAME_API_KEY>
# then paste the printed apx-... token here. Leave blank for read-only (no posting).
GAME_TWITTER_ACCESS_TOKEN=

# Optional: Robinhood Chain RPC (defaults to the public mainnet RPC)
RPC_URL=https://rpc.mainnet.chain.robinhood.com
